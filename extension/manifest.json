{
  "manifest_version": 3,
  "name": "Meeting Capture System",
  "key": "",
  "version": "0.1.0",
  "description": "Local-first Google Meet capture: captions, participants, and audio coordination.",
  "permissions": ["storage", "scripting", "alarms", "tabCapture", "offscreen", "activeTab", "tabs", "notifications", "nativeMessaging"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meetContent.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["captureContent.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Meeting Capture"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+R", "mac": "Command+Shift+R" },
      "description": "Toggle capture recording"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
