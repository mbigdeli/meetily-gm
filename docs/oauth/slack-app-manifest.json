{
  "display_information": {
    "name": "Miting",
    "description": "Local-first meeting assistant — posts recaps and reads your channels as you.",
    "background_color": "#611f69"
  },
  "oauth_config": {
    "redirect_urls": [
      "https://mbigdeli.github.io/meetily-gm/oauth/slack-callback.html"
    ],
    "scopes": {
      "user": [
        "channels:read",
        "groups:read",
        "chat:write",
        "search:read"
      ]
    }
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
